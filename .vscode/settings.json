{
  "css.lint.unknownAtRules": "ignore",
  "css.lint.validProperties": [
    "color",
    "*-color",
    "background",
    "font",
    "font-family",
    "font-size",
    "padding",
    "margin",
    "display",
    "flex",
    "grid",
    "border",
    "border-radius",
    "box-shadow",
    "transform",
    "transition",
    "animation",
    "opacity",
    "width",
    "height",
    "gap",
    "cursor",
    "position",
    "top",
    "right",
    "bottom",
    "left",
    "z-index",
    "overflow",
    "visibility",
    "pointer-events",
    "backdrop-filter",
    "filter",
    "text-align",
    "text-transform",
    "white-space",
    "word-break",
    "line-height",
    "letter-spacing"
  ],
  "scss.lint.unknownAtRules": "ignore",
  "tailwindCSS.experimental.classRegex": [
    "className=\"([^\"]*)\"",
    "className=\\{`([^`]*)`\\}"
  ]
}
